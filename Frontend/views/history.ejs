<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Patient History</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/role-styles.css">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
</head>
<body class="page-container">

    <header class="main-header">
        <div class="app-info">
            <span class="app-logo">📚</span>
            <h1>Patient History</h1>
        </div>
        <div class="header-action">
            <span class="material-icons">info_outline</span>
        </div>
    </header>

    <%
        const safeArray = (v) => Array.isArray(v) ? v : [];
        const analysisRoot = (row) => {
            const payload = row && row.analysis_json;
            if (!payload || typeof payload !== 'object') return null;
            if (payload.analysis && typeof payload.analysis === 'object') return payload.analysis;
            return payload;
        };
        const getSymptoms = (row) => {
            const payload = row && row.analysis_json;
            const root = analysisRoot(row);
            const raw = (payload && payload.symptoms_detected && payload.symptoms_detected.symptoms)
                || (root && root.symptoms_detected && root.symptoms_detected.symptoms);
            if (Array.isArray(raw)) return raw.map(s => String(s).trim()).filter(Boolean);
            if (typeof raw === 'string') return raw.split(',').map(s => s.trim()).filter(Boolean);
            return [];
        };
        const getPrescription = (row) => {
            const root = analysisRoot(row);
            if (!root) return null;
            return root.doctor_prescription || root.doctorPrescription || null;
        };
        const formatMedicationEntry = (m) => {
            if (!m) return null;
            if (typeof m === 'string') return m.trim() || null;
            if (typeof m !== 'object') return null;

            const name =
                m.name || m.medication || m.medicine || m.drug || m.medication_name || m.medicationName || m.medName;
            if (!name) return null;

            const dosage = m.dosage || m.dose || m.strength || m.quantity || m.amount;
            const frequency = m.frequency || m.freq || m.timing || m.when || m.schedule;
            const duration = m.duration || m.days || m.period || m.for;

            const details = [dosage, frequency, duration].filter(Boolean).map(v => String(v).trim()).filter(Boolean).join(", ");
            return details ? `${String(name).trim()} (${details})` : String(name).trim();
        };
        const formatMedications = (medications) => {
            if (!medications) return "";
            if (typeof medications === 'string') return medications.trim();
            if (!Array.isArray(medications)) return "";
            return medications.map(formatMedicationEntry).filter(Boolean).join(", ");
        };
    %>

    <main class="content-area history-page">
        
        <div class="search-container">
            <div class="input-group search-bar">
                <span class="material-icons">search</span>
                <input type="text" id="patientSearch" placeholder="Search by Name or Patient ID..." onkeyup="filterHistory()">
            </div>
        </div>

        <h2 class="section-title">All Patient Records</h2>

        <section class="history-list" id="historyList">
            <% if (typeof records !== 'undefined' && records && records.length) { %>
                <% records.forEach(row => { 
                    const detailId = `PID${row.patientid}-S${row.sessionid}`;
                    const symptoms = getSymptoms(row);
                    const prescription = getPrescription(row) || {};
                    const diagnosis = prescription.disease || prescription.diagnosis || "";
                    const meds = formatMedications(prescription.medications || prescription.meds || prescription.drugs);
                    const createdDate = row.created_at ? new Date(row.created_at) : null;
                    const createdLabel = createdDate ? createdDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '';
                %>
                    <div class="date-group">
                        <div class="history-item" onclick="toggleDetails('<%= detailId %>')">
                            <div class="item-summary">
                                <p class="name"><%= (row.firstname || '') + ' ' + (row.lastname || '') %></p>
                                <p class="id">PID<%= row.patientid %></p>
                                <span class="material-icons expand-icon">expand_more</span>
                            </div>
                            <div class="item-details" id="<%= detailId %>">
                                <h4>Consultation Summary <%= createdLabel ? '(' + createdLabel + ')' : '' %></h4>
                                <p><strong>Chief Complaint:</strong> <%= symptoms.length ? symptoms.join(', ') : '—' %></p>
                                <p><strong>Diagnosis:</strong> <%= diagnosis ? diagnosis : '—' %></p>
                                <p><strong>Medication:</strong> <%= meds ? meds : '—' %></p>
                                <button class="btn btn-details" onclick="event.stopPropagation(); viewFullRecord('<%= row.patientid %>', '<%= row.sessionid %>')">View Full Record</button>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="date-group">
                    <div class="history-item" style="cursor: default;">
                        <div class="item-summary">
                            <p class="name">No records yet</p>
                            <p class="id"></p>
                            <span class="material-icons expand-icon">history</span>
                        </div>
                    </div>
                </div>
            <% } %>
        </section>

    </main>

    <% 
        const userRole = 'doctor'; 
        const currentPage = 'history';
    %>
    <%- include('includes/navbar.ejs', { userRole: userRole, currentPage: currentPage }) %>

    <script src="/js/main.js"></script>
    <script src="/js/history.js"></script>
</body>
</html>
